# Lowest-friction profile for smaller edge devices and CPU-only deployments.
EDGE_LLM_PROFILE=lite
EDGE_LLM_MODEL_FILE=tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf
EDGE_LLM_MODEL_PATH=/models/tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf
EDGE_LLM_REQUIREMENTS_FILE=requirements.txt
EDGE_LLM_CTX_SIZE=2048
EDGE_LLM_THREADS=4
EDGE_LLM_N_PREDICT=128
EDGE_LLM_TEMPERATURE=0.6
LLAMA_STREAM_TIMEOUT_SECONDS=60
