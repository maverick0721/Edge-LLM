# Highest-quality runtime tuning. Replace EDGE_LLM_MODEL_FILE with a larger GGUF
# when the target device has enough RAM and CPU/GPU headroom.
EDGE_LLM_PROFILE=high-quality
EDGE_LLM_MODEL_FILE=tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf
EDGE_LLM_MODEL_PATH=/models/tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf
EDGE_LLM_REQUIREMENTS_FILE=requirements-high-quality.txt
EDGE_LLM_CTX_SIZE=4096
EDGE_LLM_THREADS=8
EDGE_LLM_N_PREDICT=256
EDGE_LLM_TEMPERATURE=0.65
LLAMA_STREAM_TIMEOUT_SECONDS=60
